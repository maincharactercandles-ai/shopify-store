{% liquid
  assign selected_collection = product.metafields.custom.drop_collection.value

  if selected_collection == blank
    assign selected_collection = section.settings.collection
  endif
%}

<section
  id="NWY-Related-{{ section.id }}"
  class="nwy-related"
  style="
    --nwy-related-bg: {{ section.settings.background_color }};
    --nwy-related-text: {{ section.settings.text_color }};
    --nwy-related-muted: {{ section.settings.muted_text_color }};
    --nwy-related-card-bg: {{ section.settings.card_background }};
    --nwy-related-line: {{ section.settings.line_color }};
    --nwy-related-gutter: {{ section.settings.side_gutter }}px;
    --nwy-related-max-width: {{ section.settings.max_width }}px;
    --nwy-related-pt: {{ section.settings.padding_top }}px;
    --nwy-related-pb: {{ section.settings.padding_bottom }}px;
    --nwy-related-ratio: {{ section.settings.image_ratio }};
  "
>
  <div class="nwy-related__inner">
    <div class="nwy-related__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="nwy-related__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="nwy-related__title">{{ section.settings.title | escape }}</h2>
        {% endif %}
      </div>

      {% if selected_collection != blank and section.settings.button_label != blank %}
        <a class="nwy-related__header-link" href="{{ selected_collection.url }}">
          <span>{{ section.settings.button_label | escape }}</span>
          <span aria-hidden="true">↗</span>
        </a>
      {% endif %}
    </div>

    {% if selected_collection != blank and selected_collection.products_count > 0 %}
      <div
        class="nwy-related__grid"
        role="list"
        style="--nwy-related-columns: {{ section.settings.columns_desktop }};"
      >
        {% assign shown_count = 0 %}

        {% for related_product in selected_collection.products %}
          {% if related_product.id != product.id %}
            {% assign shown_count = shown_count | plus: 1 %}

            <article class="nwy-related-card" role="listitem">
              <a class="nwy-related-card__link" href="{{ related_product.url }}">
                <div class="nwy-related-card__media">
                  {% if related_product.featured_media != blank %}
                    {{
                      related_product.featured_media
                      | image_url: width: 1400
                      | image_tag:
                        class: 'nwy-related-card__image',
                        widths: '320, 480, 640, 800, 1000, 1200, 1400',
                        sizes: '(min-width: 1200px) 30vw, (min-width: 750px) 46vw, 86vw',
                        loading: 'lazy',
                        alt: related_product.featured_media.alt | default: related_product.title
                    }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'nwy-related-card__placeholder' }}
                  {% endif %}
                </div>

                <div class="nwy-related-card__content">
                  <div>
                    {% if section.settings.show_object_number %}
                      <p class="nwy-related-card__object">
                        {{ related_product.metafields.custom.object_number.value | default: related_product.title | escape }}
                      </p>
                    {% endif %}

                    <h3 class="nwy-related-card__title">{{ related_product.title | escape }}</h3>
                  </div>

                  {% if section.settings.show_price %}
                    <div class="nwy-related-card__price">
                      {% if related_product.price_varies %}
                        {{ related_product.price_min | money }}
                      {% else %}
                        {{ related_product.price | money }}
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </a>
            </article>

            {% if shown_count >= section.settings.products_to_show %}
              {% break %}
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="nwy-related__empty">
        <p>Sélectionne la collection à afficher.</p>
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  #NWY-Related-{{ section.id }} {
    background: var(--nwy-related-bg);
    color: var(--nwy-related-text);
    padding-block: var(--nwy-related-pt) var(--nwy-related-pb);
  }

  #NWY-Related-{{ section.id }} * {
    box-sizing: border-box;
  }

  #NWY-Related-{{ section.id }} .nwy-related__inner {
    width: min(calc(100% - (var(--nwy-related-gutter) * 2)), var(--nwy-related-max-width));
    margin-inline: auto;
  }

  #NWY-Related-{{ section.id }} .nwy-related__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 30px;
    margin-bottom: clamp(30px, 4vw, 58px);
  }

  #NWY-Related-{{ section.id }} .nwy-related__eyebrow {
    margin: 0 0 14px;
    color: var(--nwy-related-muted);
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #NWY-Related-{{ section.id }} .nwy-related__title {
    max-width: 10ch;
    margin: 0;
    color: var(--nwy-related-text);
    font-size: clamp(42px, 5vw, 84px);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  #NWY-Related-{{ section.id }} .nwy-related__header-link {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    padding-bottom: 4px;
    border-bottom: 1px solid currentColor;
    color: var(--nwy-related-text);
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.09em;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #NWY-Related-{{ section.id }} .nwy-related__grid {
    display: grid;
    grid-template-columns: repeat(var(--nwy-related-columns), minmax(0, 1fr));
    gap: clamp(20px, 2.4vw, 42px);
  }

  #NWY-Related-{{ section.id }} .nwy-related-card {
    min-width: 0;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--nwy-related-ratio);
    background: var(--nwy-related-card-bg);
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__image,
  #NWY-Related-{{ section.id }} .nwy-related-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__image {
    object-fit: cover;
    transform: scale(1.001);
    transition: transform 800ms cubic-bezier(0.2, 0.75, 0.25, 1);
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__link:hover .nwy-related-card__image {
    transform: scale(1.035);
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__content {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding-top: 15px;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__object {
    margin: 0 0 7px;
    color: var(--nwy-related-muted);
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__title {
    margin: 0;
    color: var(--nwy-related-text);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  #NWY-Related-{{ section.id }} .nwy-related-card__price {
    flex: 0 0 auto;
    font-size: 12px;
    line-height: 1.2;
    white-space: nowrap;
  }

  #NWY-Related-{{ section.id }} .nwy-related__empty {
    padding: 48px 0;
    border-top: 1px solid var(--nwy-related-line);
    color: var(--nwy-related-muted);
    font-size: 13px;
  }

  @media screen and (max-width: 989px) {
    #NWY-Related-{{ section.id }} .nwy-related__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    #NWY-Related-{{ section.id }} {
      padding-block: calc(var(--nwy-related-pt) * 0.72) calc(var(--nwy-related-pb) * 0.72);
    }

    #NWY-Related-{{ section.id }} .nwy-related__inner {
      width: calc(100% - 32px);
    }

    #NWY-Related-{{ section.id }} .nwy-related__header {
      display: block;
      margin-bottom: 34px;
    }

    #NWY-Related-{{ section.id }} .nwy-related__header-link {
      margin-top: 22px;
    }

    #NWY-Related-{{ section.id }} .nwy-related__title {
      font-size: clamp(42px, 13vw, 66px);
    }

    #NWY-Related-{{ section.id }} .nwy-related__grid {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 84%;
      grid-template-columns: none;
      gap: 16px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding-bottom: 6px;
    }

    #NWY-Related-{{ section.id }} .nwy-related__grid::-webkit-scrollbar {
      display: none;
    }

    #NWY-Related-{{ section.id }} .nwy-related-card {
      scroll-snap-align: start;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "NWY — Related objects",
  "tag": "section",
  "class": "section-nwy-related",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "THE COLLECTION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "MORE OBJECTS."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Produits à afficher",
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Colonnes sur ordinateur",
      "default": 2
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Lien vers la collection",
      "default": "DISCOVER THE DROP"
    },
    {
      "type": "header",
      "content": "Cartes"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format des images",
      "default": "4 / 5",
      "options": [
        { "value": "1 / 1", "label": "Carré" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "3 / 4", "label": "Portrait long" },
        { "value": "4 / 3", "label": "Paysage" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_object_number",
      "label": "Afficher le numéro ou nom de l’objet",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Afficher le prix",
      "default": true
    },
    {
      "type": "header",
      "content": "Largeur et couleurs"
    },
    {
      "type": "range",
      "id": "side_gutter",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marges latérales",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1200,
      "max": 2400,
      "step": 100,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 2000
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond",
      "default": "#F6F5F1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Texte secondaire",
      "default": "#6E6E68"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Traits",
      "default": "#D8D7D1"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond des images",
      "default": "#E8E6E0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "NWY — Related objects"
    }
  ]
}
{% endschema %}

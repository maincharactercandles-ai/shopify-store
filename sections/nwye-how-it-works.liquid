
<div class="section-background" style="background: {{ section.settings.background_color }};"></div>

<div
  class="section section--page-width nwye-how-it-works"
  style="
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="nwye-how-it-works__wrap">

    <div class="nwye-how-it-works__header">
      {%- if section.settings.label != blank -%}
        <p class="nwye-how-it-works__label">{{ section.settings.label }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="nwye-how-it-works__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <div class="nwye-how-it-works__steps">
      {%- for block in section.blocks -%}
        <div class="nwye-how-it-works__step" {{ block.shopify_attributes }}>
          <div
            class="nwye-how-it-works__step-icon"
            style="background: {{ block.settings.icon_bg }}; color: {{ block.settings.icon_color }};"
          >
            {{ forloop.index | prepend: '0' | slice: -2, 2 }}
          </div>
          {%- if block.settings.title != blank -%}
            <div class="nwye-how-it-works__step-title">{{ block.settings.title }}</div>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="nwye-how-it-works__step-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
.nwye-how-it-works__wrap {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-width-padding, 24px);
}
.nwye-how-it-works__header {
  text-align: center;
  margin-bottom: 64px;
}
.nwye-how-it-works__label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.55;
  margin-bottom: 16px;
}
.nwye-how-it-works__title {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}
.nwye-how-it-works__steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.nwye-how-it-works__step {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.15);
  padding: 48px 32px;
  border-radius: 4px;
}
.nwye-how-it-works__step-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 20px;
}
.nwye-how-it-works__step-title {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 12px;
}
.nwye-how-it-works__step-text {
  font-size: 0.875rem;
  line-height: 1.7;
  opacity: 0.75;
}
@media screen and (max-width: 900px) {
  .nwye-how-it-works__steps {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#097e14"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (small caps)",
      "default": "The NWYE experience"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "From choice to delivery,\nevery detail counts."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Pick your piece"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Step description",
          "default": "Browse the collection and find the candle that speaks to you — or the one that'll speak for you as a gift."
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Icon background",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Icon text color",
          "default": "#1800ad"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Pick your piece",
            "text": "Browse the collection and find the candle that speaks to you — or the one that'll speak for you as a gift.",
            "icon_bg": "#ffffff",
            "icon_color": "#1800ad"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Signature packaging",
            "text": "Every order is carefully wrapped in our signature packaging. Ready to give, ready to display — straight out of the box.",
            "icon_bg": "#fbb91d",
            "icon_color": "#000000"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Fast delivery",
            "text": "Shipped within 48 hours. Tracked delivery across France and Europe. Easy returns if something isn't right.",
            "icon_bg": "#ffffff",
            "icon_color": "#097e14"
          }
        }
      ]
    }
  ]
}
{% endschema %}

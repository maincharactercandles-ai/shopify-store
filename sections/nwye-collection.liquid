{%- assign col = section.settings.collection -%}
{%- if col != blank -%}
  {%- assign products = col.products -%}
{%- else -%}
  {%- assign products = collections.all.products -%}
{%- endif -%}

<div class="nwye-collection" style="background:#ffffff; padding:64px 24px;">
  <div style="max-width:1200px; margin:0 auto;">

    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px;">
      <span style="font-size:0.95rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase;">
        {{ section.settings.title }}
      </span>
      {%- if section.settings.show_view_all and col != blank -%}
        <a href="{{ col.url }}" style="font-size:0.75rem; font-weight:500; letter-spacing:0.06em; color:#000; text-decoration:none; border-bottom:1px solid #000; padding-bottom:2px;">
          {{ section.settings.view_all_label }} →
        </a>
      {%- endif -%}
    </div>

    <div class="nwye-col-grid" style="display:grid; grid-template-columns:repeat({{ section.settings.columns }},1fr); gap:2px;">
      {%- for product in products limit: section.settings.products_count -%}
        <a href="{{ product.url }}" style="text-decoration:none; color:#000;" class="nwye-col-card">
          <div style="aspect-ratio:1/1; background:#BFBFBE; overflow:hidden;">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;', class: 'nwye-col-img' }}
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;opacity:0.3;">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
          <div style="padding:12px 0 0;">
            <div style="font-size:0.8rem; font-weight:500; letter-spacing:0.05em; text-transform:uppercase;">
              {{ product.title }}
            </div>
            <div style="font-size:0.8rem; margin-top:4px; opacity:0.6;">
              {{ product.price | money }}
            </div>
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..section.settings.products_count) -%}
          <div>
            <div style="aspect-ratio:1/1; background:#BFBFBE; display:flex;align-items:center;justify-content:center;opacity:0.3;">
              {{ 'product-' | append: i | placeholder_svg_tag }}
            </div>
            <div style="padding:12px 0 0;">
              <div style="font-size:0.8rem; font-weight:500; letter-spacing:0.05em; text-transform:uppercase;">Product</div>
              <div style="font-size:0.8rem; margin-top:4px; opacity:0.6;">— €</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  .nwye-col-card:hover .nwye-col-img { transform: scale(1.04); }
  @media (max-width:768px) {
    .nwye-col-grid { grid-template-columns: repeat(2,1fr) !important; }
  }
</style>

{% schema %}
{
  "name": "The Collection",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "The Collection."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show \"View all\" link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "\"View all\" label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "The Collection"
    }
  ]
}
{% endschema %}

{% liquid
  assign sid = section.id
%}

<section id="nwy-why-{{ sid }}" class="nwy-why">

  <div class="nwy-why__container">

    {% if section.settings.heading != blank %}
      <div class="nwy-why__header">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="nwy-why__grid">

      <!-- CARD 1 -->
      <article class="nwy-why__card">

        {% if section.settings.image_1 != blank %}
          <div class="nwy-why__image">
            {{
              section.settings.image_1
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '400,600,800,1200',
                class: 'nwy-why__img'
            }}
          </div>
        {% endif %}

        <div class="nwy-why__content">

          {% if section.settings.title_1 != blank %}
            <h3>{{ section.settings.title_1 }}</h3>
          {% endif %}

          {% if section.settings.text_1 != blank %}
            <p>{{ section.settings.text_1 }}</p>
          {% endif %}

        </div>

      </article>
            <!-- CARD 2 -->
      <article class="nwy-why__card">

        {% if section.settings.image_2 != blank %}
          <div class="nwy-why__image">
            {{
              section.settings.image_2
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '400,600,800,1200',
                class: 'nwy-why__img'
            }}
          </div>
        {% endif %}

        <div class="nwy-why__content">

          {% if section.settings.title_2 != blank %}
            <h3>{{ section.settings.title_2 }}</h3>
          {% endif %}

          {% if section.settings.text_2 != blank %}
            <p>{{ section.settings.text_2 }}</p>
          {% endif %}

        </div>

      </article>

      <!-- CARD 3 -->
      <article class="nwy-why__card">

        {% if section.settings.image_3 != blank %}
          <div class="nwy-why__image">
            {{
              section.settings.image_3
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                widths: '400,600,800,1200',
                class: 'nwy-why__img'
            }}
          </div>
        {% endif %}

        <div class="nwy-why__content">

          {% if section.settings.title_3 != blank %}
            <h3>{{ section.settings.title_3 }}</h3>
          {% endif %}

          {% if section.settings.text_3 != blank %}
            <p>{{ section.settings.text_3 }}</p>
          {% endif %}

        </div>

      </article>
          </div>
  </div>
</section>

{% style %}

#nwy-why-{{ sid }}{
  background:{{ section.settings.background }};
  color:{{ section.settings.text_color }};
  padding:{{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
}

#nwy-why-{{ sid }} *{
  box-sizing:border-box;
}

#nwy-why-{{ sid }} .nwy-why__container{
  width:min(calc(100% - 80px),1600px);
  margin:0 auto;
}

#nwy-why-{{ sid }} .nwy-why__header{
  margin-bottom:72px;
}

#nwy-why-{{ sid }} .nwy-why__header h2{
  margin:0;
  max-width:9ch;
  font-size:clamp(54px,6vw,104px);
  line-height:.9;
  font-weight:700;
  letter-spacing:-0.06em;
  text-transform:uppercase;
}

#nwy-why-{{ sid }} .nwy-why__grid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:32px;
}

#nwy-why-{{ sid }} .nwy-why__card{
  display:flex;
  flex-direction:column;
}

#nwy-why-{{ sid }} .nwy-why__image{
  position:relative;
  overflow:hidden;
  aspect-ratio:4/5;
  background:#efefeb;
}

#nwy-why-{{ sid }} .nwy-why__img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
  transition:transform .8s cubic-bezier(.2,.7,.2,1);
}

#nwy-why-{{ sid }} .nwy-why__card:hover .nwy-why__img{
  transform:scale(1.04);
}

#nwy-why-{{ sid }} .nwy-why__content{
  padding-top:22px;
}

#nwy-why-{{ sid }} .nwy-why__content h3{
  margin:0 0 12px;
  font-size:20px;
  line-height:1.1;
  font-weight:600;
  letter-spacing:-.03em;
}

#nwy-why-{{ sid }} .nwy-why__content p{
  margin:0;
  font-size:15px;
  line-height:1.65;
  color:#666;
}
#nwy-why-{{ sid }} .nwy-why__content h3{
  transition:transform .35s ease,color .35s ease;
}

#nwy-why-{{ sid }} .nwy-why__card:hover h3{
  transform:translateY(-2px);
}

#nwy-why-{{ sid }} .nwy-why__card{
  cursor:default;
}

#nwy-why-{{ sid }} .nwy-why__card::after{
  content:"";
  display:block;
  width:100%;
  height:1px;
  margin-top:28px;
  background:rgba(0,0,0,.08);
  transform:scaleX(0);
  transform-origin:left;
  transition:transform .45s ease;
}

#nwy-why-{{ sid }} .nwy-why__card:hover::after{
  transform:scaleX(1);
}

#nwy-why-{{ sid }} .nwy-why__content{
  display:flex;
  flex-direction:column;
  flex:1;
}

#nwy-why-{{ sid }} .nwy-why__content p{
  max-width:36ch;
}

#nwy-why-{{ sid }} .nwy-why__header{
  display:flex;
  justify-content:space-between;
  align-items:flex-end;
  gap:40px;
}

#nwy-why-{{ sid }} .nwy-why__eyebrow{
  margin:0 0 14px;
  font-size:11px;
  text-transform:uppercase;
  letter-spacing:.12em;
  color:#8b8b8b;
}

#nwy-why-{{ sid }} .nwy-why__image::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(
      rgba(255,255,255,0),
      rgba(255,255,255,.03)
  );
  opacity:0;
  transition:opacity .45s ease;
}

#nwy-why-{{ sid }} .nwy-why__card:hover .nwy-why__image::after{
  opacity:1;
}

@media screen and (max-width:1200px){

#nwy-why-{{ sid }} .nwy-why__container{
width:min(calc(100% - 48px),1300px);
}

#nwy-why-{{ sid }} .nwy-why__grid{
gap:24px;
}

#nwy-why-{{ sid }} .nwy-why__header h2{
font-size:clamp(48px,6vw,84px);
}

}

@media screen and (max-width:989px){

#nwy-why-{{ sid }} .nwy-why__grid{
grid-template-columns:1fr;
gap:56px;
}

#nwy-why-{{ sid }} .nwy-why__image{
aspect-ratio:3/4;
}

#nwy-why-{{ sid }} .nwy-why__content p{
max-width:100%;
}

}

@media screen and (max-width:749px){

#nwy-why-{{ sid }}{

padding:
calc({{ section.settings.padding_top }}px*.7)
0
calc({{ section.settings.padding_bottom }}px*.7);

}

#nwy-why-{{ sid }} .nwy-why__container{

width:calc(100% - 32px);

}

#nwy-why-{{ sid }} .nwy-why__header{

margin-bottom:42px;

}

#nwy-why-{{ sid }} .nwy-why__header h2{

font-size:clamp(42px,13vw,64px);

}

#nwy-why-{{ sid }} .nwy-why__content{

padding-top:18px;

}

#nwy-why-{{ sid }} .nwy-why__content h3{

font-size:22px;

}

#nwy-why-{{ sid }} .nwy-why__content p{

font-size:15px;
line-height:1.7;

}

}

{% endstyle %}
{% schema %}
{
  "name": "NWY — Why",
  "tag": "section",
  "class": "section-nwy-why",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHY NOT WHAT YOU EXPECT?"
    },

    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title",
      "default": "Unexpected Objects"
    },
    {
      "type": "textarea",
      "id": "text_1",
      "label": "Text",
      "default": "Industrial objects transformed into scented candles designed to surprise."
    },

    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title",
      "default": "Hand-poured in Paris"
    },
    {
      "type": "textarea",
      "id": "text_2",
      "label": "Text",
      "default": "Each candle is hand-poured in small batches using vegan soy wax and fragrances from Grasse."
    },

    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Title",
      "default": "Designed To Stay"
    },
    {
      "type": "textarea",
      "id": "text_3",
      "label": "Text",
      "default": "Once the candle has burned away, the object remains as part of your interior."
    },

    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "NWY — Why"
    }
  ]
}
{% endschema %}
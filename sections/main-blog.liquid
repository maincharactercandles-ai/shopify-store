<style>
  .nwye-journal {
    max-width: 1360px;
    margin: 0 auto;
    padding: 90px 40px 120px;
  }

  .nwye-journal__header {
    margin-bottom: 70px;
  }

  .nwye-journal__eyebrow {
    font-size: 12px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #777;
    margin-bottom: 18px;
  }

  .nwye-journal__title {
    font-size: clamp(56px, 9vw, 140px);
    line-height: .86;
    letter-spacing: -0.075em;
    text-transform: uppercase;
    margin: 0 0 28px;
  }

  .nwye-journal__intro {
    max-width: 680px;
    font-size: 20px;
    line-height: 1.45;
    color: #444;
  }

  .nwye-journal__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 64px 34px;
  }

  .nwye-article {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .nwye-article:first-child {
    grid-column: span 2;
  }

  .nwye-article__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f4f1ec;
    margin-bottom: 18px;
  }

  .nwye-article:first-child .nwye-article__image {
    aspect-ratio: 16 / 7;
  }

  .nwye-article__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .7s ease;
  }

  .nwye-article:hover img {
    transform: scale(1.035);
  }

  .nwye-article__meta {
    display: flex;
    gap: 14px;
    align-items: center;
    font-size: 11px;
    letter-spacing: .13em;
    text-transform: uppercase;
    color: #777;
    margin-bottom: 10px;
  }

  .nwye-article__title {
    font-size: clamp(28px, 3vw, 54px);
    line-height: .98;
    letter-spacing: -0.055em;
    margin: 0 0 14px;
  }

  .nwye-article:not(:first-child) .nwye-article__title {
    font-size: clamp(24px, 2vw, 34px);
  }

  .nwye-article__excerpt {
    max-width: 620px;
    font-size: 16px;
    line-height: 1.45;
    color: #555;
  }

  .nwye-journal__empty {
    font-size: 18px;
    color: #555;
  }

  .nwye-journal__footer {
    margin-top: 90px;
    padding-top: 28px;
    border-top: 1px solid #ddd;
    font-size: 12px;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #777;
  }

  @media screen and (max-width: 749px) {
    .nwye-journal {
      padding: 54px 20px 80px;
    }

    .nwye-journal__header {
      margin-bottom: 46px;
    }

    .nwye-journal__intro {
      font-size: 17px;
    }

    .nwye-journal__grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }

    .nwye-article:first-child {
      grid-column: span 1;
    }

    .nwye-article:first-child .nwye-article__image {
      aspect-ratio: 4 / 3;
    }
  }
</style>

<section class="nwye-journal">
  <header class="nwye-journal__header">
    <div class="nwye-journal__eyebrow">NOT WHAT YOU EXPECT.</div>
    <h1 class="nwye-journal__title">Journal.</h1>
    <p class="nwye-journal__intro">
      Design studies, material notes and stories behind our objects.
      A space for what inspires each collection before it becomes a candle.
    </p>
  </header>

  {% if blog.articles_count > 0 %}
    <div class="nwye-journal__grid">
      {% for article in blog.articles %}
        <a class="nwye-article" href="{{ article.url }}">
          {% if article.image %}
            <div class="nwye-article__image">
              <img
                src="{{ article.image | image_url: width: 1600 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                loading="lazy"
              >
            </div>
          {% endif %}

          <div class="nwye-article__meta">
            <span>{{ article.published_at | date: "%B %d, %Y" }}</span>
            <span>—</span>
            <span>Design Study</span>
          </div>

          <h2 class="nwye-article__title">{{ article.title }}</h2>

          {% if article.excerpt != blank %}
            <div class="nwye-article__excerpt">
              {{ article.excerpt | strip_html | truncate: 190 }}
            </div>
          {% else %}
            <div class="nwye-article__excerpt">
              {{ article.content | strip_html | truncate: 190 }}
            </div>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  {% else %}
    <p class="nwye-journal__empty">No articles yet.</p>
  {% endif %}

  <div class="nwye-journal__footer">
    New studies added regularly.
  </div>
</section>
{% liquid
  assign section_id = 'nwy-about-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="nwy-about"
  style="
    --nwy-about-bg: {{ section.settings.background_color }};
    --nwy-about-text: {{ section.settings.text_color }};
    --nwy-about-muted: {{ section.settings.muted_text_color }};
    --nwy-about-border: {{ section.settings.border_color }};
  "
>
  <div class="nwy-about__hero">
    <div class="nwy-about__container">
      <div class="nwy-about__hero-grid">
        <div class="nwy-about__hero-copy nwy-reveal">
          {% if section.settings.hero_eyebrow != blank %}
            <p class="nwy-about__eyebrow">
              {{ section.settings.hero_eyebrow | escape }}
            </p>
          {% endif %}

          {% if section.settings.hero_heading != blank %}
            <h1 class="nwy-about__hero-heading">
              {{ section.settings.hero_heading | escape | newline_to_br }}
            </h1>
          {% endif %}
        </div>

        {% if section.settings.hero_intro != blank %}
          <div class="nwy-about__hero-intro nwy-reveal">
            {{ section.settings.hero_intro }}
          </div>
        {% endif %}
      </div>
    </div>

    {% if section.settings.hero_image != blank %}
      <div class="nwy-about__hero-media nwy-reveal">
        {{
          section.settings.hero_image
          | image_url: width: 2400
          | image_tag:
            loading: 'eager',
            widths: '750, 1100, 1500, 1900, 2400',
            sizes: '100vw',
            class: 'nwy-about__hero-image',
            alt: section.settings.hero_image.alt
        }}
      </div>
    {% else %}
      <div class="nwy-about__hero-media nwy-reveal">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'nwy-about__placeholder' }}
      </div>
    {% endif %}
  </div>

  <div class="nwy-about__container">

    <section class="nwy-about__intro nwy-about__section">
      <div class="nwy-about__section-label nwy-reveal">
        {% if section.settings.idea_eyebrow != blank %}
          <p class="nwy-about__eyebrow">
            {{ section.settings.idea_eyebrow | escape }}
          </p>
        {% endif %}
      </div>

      <div class="nwy-about__intro-content">
        {% if section.settings.idea_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.idea_heading | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.idea_text != blank %}
          <div class="nwy-about__body nwy-about__body--large nwy-reveal">
            {{ section.settings.idea_text }}
          </div>
        {% endif %}
      </div>
    </section>

    <div class="nwy-about__divider"></div>

    <section class="nwy-about__object-section nwy-about__section">
      <div class="nwy-about__object-copy">
        {% if section.settings.object_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.object_heading | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.object_text != blank %}
          <div class="nwy-about__body nwy-reveal">
            {{ section.settings.object_text }}
          </div>
        {% endif %}
      </div>

      <div class="nwy-about__object-media nwy-reveal">
        {% if section.settings.object_image != blank %}
          {{
            section.settings.object_image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '600, 900, 1200, 1600',
              sizes: '(min-width: 990px) 46vw, 100vw',
              class: 'nwy-about__image',
              alt: section.settings.object_image.alt
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'nwy-about__placeholder' }}
        {% endif %}
      </div>
    </section>
  </div>

  <section class="nwy-about__statement-block">
    <div class="nwy-about__container">
      {% if section.settings.statement_text != blank %}
        <p class="nwy-about__statement nwy-reveal">
          {{ section.settings.statement_text | escape | newline_to_br }}
        </p>
      {% endif %}
    </div>
  </section>

  <div class="nwy-about__container">
    <section class="nwy-about__process nwy-about__section">
      <div class="nwy-about__process-header">
        <div class="nwy-reveal">
          {% if section.settings.process_eyebrow != blank %}
            <p class="nwy-about__eyebrow">
              {{ section.settings.process_eyebrow | escape }}
            </p>
          {% endif %}
        </div>

        {% if section.settings.process_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.process_heading | escape | newline_to_br }}
          </h2>
        {% endif %}
      </div>

      <div class="nwy-about__steps">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'process_step' %}
              <article
                class="nwy-about__step nwy-reveal"
                {{ block.shopify_attributes }}
              >
                <p class="nwy-about__step-number">
                  {{ block.settings.number | escape }}
                </p>

                {% if block.settings.heading != blank %}
                  <h3 class="nwy-about__step-heading">
                    {{ block.settings.heading | escape }}
                  </h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="nwy-about__step-text">
                    {{ block.settings.text }}
                  </div>
                {% endif %}
              </article>
          {% endcase %}
        {% endfor %}
      </div>
    </section>
  </div>

  <section class="nwy-about__wide-image nwy-reveal">
    {% if section.settings.process_image != blank %}
      {{
        section.settings.process_image
        | image_url: width: 2400
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 1900, 2400',
          sizes: '100vw',
          class: 'nwy-about__wide-image-element',
          alt: section.settings.process_image.alt
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'nwy-about__placeholder' }}
    {% endif %}
  </section>

  <div class="nwy-about__container">
    <section class="nwy-about__materials nwy-about__section">
      <div class="nwy-about__materials-copy">
        {% if section.settings.materials_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.materials_heading | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.materials_text != blank %}
          <div class="nwy-about__body nwy-reveal">
            {{ section.settings.materials_text }}
          </div>
        {% endif %}
      </div>

      <div class="nwy-about__materials-list">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'material' %}
              <div
                class="nwy-about__material nwy-reveal"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.number != blank %}
                  <span class="nwy-about__material-number">
                    {{ block.settings.number | escape }}
                  </span>
                {% endif %}

                <p>{{ block.settings.title | escape }}</p>
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    </section>

    <div class="nwy-about__divider"></div>

    <section class="nwy-about__after nwy-about__section">
      <div class="nwy-about__after-heading">
        {% if section.settings.after_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.after_heading | escape | newline_to_br }}
          </h2>
        {% endif %}
      </div>

      <div class="nwy-about__after-copy">
        {% if section.settings.after_text != blank %}
          <div class="nwy-about__body nwy-about__body--large nwy-reveal">
            {{ section.settings.after_text }}
          </div>
        {% endif %}
      </div>
    </section>

    <section class="nwy-about__gallery">
      <div class="nwy-about__gallery-main nwy-reveal">
        {% if section.settings.gallery_image_1 != blank %}
          {{
            section.settings.gallery_image_1
            | image_url: width: 1800
            | image_tag:
              loading: 'lazy',
              widths: '750, 1100, 1400, 1800',
              sizes: '(min-width: 990px) 60vw, 100vw',
              class: 'nwy-about__image',
              alt: section.settings.gallery_image_1.alt
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'nwy-about__placeholder' }}
        {% endif %}
      </div>

      <div class="nwy-about__gallery-side">
        <div class="nwy-about__gallery-small nwy-reveal">
          {% if section.settings.gallery_image_2 != blank %}
            {{
              section.settings.gallery_image_2
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                widths: '420, 640, 850, 1000',
                sizes: '(min-width: 990px) 34vw, 100vw',
                class: 'nwy-about__image',
                alt: section.settings.gallery_image_2.alt
            }}
          {% else %}
            {{ 'product-2' | placeholder_svg_tag: 'nwy-about__placeholder' }}
          {% endif %}
        </div>

        <div class="nwy-about__gallery-small nwy-reveal">
          {% if section.settings.gallery_image_3 != blank %}
            {{
              section.settings.gallery_image_3
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                widths: '420, 640, 850, 1000',
                sizes: '(min-width: 990px) 34vw, 100vw',
                class: 'nwy-about__image',
                alt: section.settings.gallery_image_3.alt
            }}
          {% else %}
            {{ 'product-3' | placeholder_svg_tag: 'nwy-about__placeholder' }}
          {% endif %}
        </div>
      </div>
    </section>

    <section class="nwy-about__studio nwy-about__section">
      <div class="nwy-about__studio-media nwy-reveal">
        {% if section.settings.studio_image != blank %}
          {{
            section.settings.studio_image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '600, 900, 1200, 1600',
              sizes: '(min-width: 990px) 48vw, 100vw',
              class: 'nwy-about__image',
              alt: section.settings.studio_image.alt
          }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'nwy-about__placeholder' }}
        {% endif %}
      </div>

      <div class="nwy-about__studio-copy">
        {% if section.settings.studio_eyebrow != blank %}
          <p class="nwy-about__eyebrow nwy-reveal">
            {{ section.settings.studio_eyebrow | escape }}
          </p>
        {% endif %}

        {% if section.settings.studio_heading != blank %}
          <h2 class="nwy-about__display-heading nwy-reveal">
            {{ section.settings.studio_heading | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.studio_text != blank %}
          <div class="nwy-about__body nwy-reveal">
            {{ section.settings.studio_text }}
          </div>
        {% endif %}
      </div>
    </section>

    <section class="nwy-about__final">
      {% if section.settings.final_heading != blank %}
        <h2 class="nwy-about__final-heading nwy-reveal">
          {{ section.settings.final_heading | escape | newline_to_br }}
        </h2>
      {% endif %}

      <div class="nwy-about__final-bottom">
        {% if section.settings.final_text != blank %}
          <p class="nwy-about__final-text nwy-reveal">
            {{ section.settings.final_text | escape }}
          </p>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a
            href="{{ section.settings.button_link }}"
            class="nwy-about__button nwy-reveal"
          >
            <span>{{ section.settings.button_label | escape }}</span>

            <svg
              aria-hidden="true"
              viewBox="0 0 18 18"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M3 9H15M10 4L15 9L10 14"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="square"
              />
            </svg>
          </a>
        {% endif %}
      </div>
    </section>
  </div>
</section>

{% style %}
  #{{ section_id }} {
    overflow: hidden;
    background: var(--nwy-about-bg);
    color: var(--nwy-about-text);
  }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after {
    box-sizing: border-box;
  }

  #{{ section_id }} h1,
  #{{ section_id }} h2,
  #{{ section_id }} h3,
  #{{ section_id }} p {
    margin-top: 0;
  }

  #{{ section_id }} .nwy-about__container {
    width: min(100%, 1860px);
    margin: 0 auto;
    padding-inline: clamp(20px, 4vw, 72px);
  }

  #{{ section_id }} .nwy-about__section {
    padding-block: clamp(90px, 11vw, 190px);
  }

  #{{ section_id }} .nwy-about__divider {
    width: 100%;
    height: 1px;
    background: var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__eyebrow {
    margin-bottom: 22px;
    font-size: 11px;
    font-weight: 650;
    line-height: 1;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__hero {
    padding-top: clamp(70px, 9vw, 140px);
  }

  #{{ section_id }} .nwy-about__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(300px, 0.55fr);
    gap: clamp(60px, 10vw, 180px);
    align-items: end;
    padding-bottom: clamp(65px, 8vw, 120px);
  }

  #{{ section_id }} .nwy-about__hero-heading {
    max-width: 1300px;
    margin-bottom: 0;
    font-size: clamp(72px, 11vw, 190px);
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.075em;
    text-transform: uppercase;
  }

#{{ section_id }} .nwy-about__hero-intro {
  max-width: 430px;
  padding-bottom: 0;
  font-family: var(--font-body-family);
  font-size: clamp(18px, 1.2vw, 21px);
  font-weight: 400;
  font-style: normal;
  letter-spacing: -0.01em;
  line-height: 1.55;
  color: var(--nwy-about-text);
}

#{{ section_id }} .nwy-about__hero-intro p {
  margin: 0 0 56px;
}

#{{ section_id }} .nwy-about__hero-intro p:last-child {
  margin-bottom: 0;
}

  #{{ section_id }} .nwy-about__hero-intro p {
    margin-bottom: 18px;
  }

  #{{ section_id }} .nwy-about__hero-intro p:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .nwy-about__hero-media {
    width: 100%;
    height: clamp(520px, 72vw, 1050px);
    overflow: hidden;
    background: #e7e7e7;
  }

  #{{ section_id }} .nwy-about__hero-image,
  #{{ section_id }} .nwy-about__wide-image-element,
  #{{ section_id }} .nwy-about__image,
  #{{ section_id }} .nwy-about__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #{{ section_id }} .nwy-about__intro {
    display: grid;
    grid-template-columns: minmax(160px, 0.45fr) minmax(0, 1.55fr);
    gap: clamp(50px, 10vw, 180px);
  }

  #{{ section_id }} .nwy-about__intro-content {
    max-width: 1250px;
  }

  #{{ section_id }} .nwy-about__display-heading {
    max-width: 1200px;
    margin-bottom: clamp(42px, 6vw, 90px);
    font-size: clamp(54px, 7.5vw, 130px);
    font-weight: 700;
    line-height: 0.84;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__body {
    max-width: 690px;
    margin-left: auto;
    color: var(--nwy-about-muted);
    font-size: clamp(17px, 1.35vw, 22px);
    line-height: 1.5;
  }

  #{{ section_id }} .nwy-about__body--large {
    font-size: clamp(20px, 1.85vw, 30px);
    line-height: 1.42;
  }

  #{{ section_id }} .nwy-about__body p {
    margin-bottom: 1.1em;
  }

  #{{ section_id }} .nwy-about__body p:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .nwy-about__object-section {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(55px, 9vw, 150px);
    align-items: center;
  }

  #{{ section_id }} .nwy-about__object-copy .nwy-about__body {
    margin-left: 0;
  }

  #{{ section_id }} .nwy-about__object-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #e7e7e7;
  }

  #{{ section_id }} .nwy-about__statement-block {
    padding-block: clamp(100px, 15vw, 250px);
    background: var(--nwy-about-text);
    color: var(--nwy-about-bg);
  }

  #{{ section_id }} .nwy-about__statement {
    max-width: 1700px;
    margin-bottom: 0;
    font-size: clamp(64px, 10vw, 180px);
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.075em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__process-header {
    display: grid;
    grid-template-columns: minmax(160px, 0.45fr) minmax(0, 1.55fr);
    gap: clamp(50px, 10vw, 180px);
  }

  #{{ section_id }} .nwy-about__steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: clamp(70px, 10vw, 150px);
    border-top: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__step {
    min-height: 340px;
    padding: 26px clamp(20px, 2.5vw, 42px) 30px 0;
    border-right: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__step:not(:first-child) {
    padding-left: clamp(20px, 2.5vw, 42px);
  }

  #{{ section_id }} .nwy-about__step:last-child {
    border-right: 0;
  }

  #{{ section_id }} .nwy-about__step-number {
    margin-bottom: 85px;
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.12em;
  }

  #{{ section_id }} .nwy-about__step-heading {
    margin-bottom: 18px;
    font-size: clamp(22px, 2vw, 34px);
    font-weight: 650;
    line-height: 1;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__step-text {
    max-width: 300px;
    color: var(--nwy-about-muted);
    font-size: 15px;
    line-height: 1.5;
  }

  #{{ section_id }} .nwy-about__step-text p {
    margin-bottom: 0;
  }

  #{{ section_id }} .nwy-about__wide-image {
    width: 100%;
    height: clamp(500px, 70vw, 1050px);
    overflow: hidden;
  }

  #{{ section_id }} .nwy-about__materials {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(350px, 0.85fr);
    gap: clamp(65px, 10vw, 170px);
    align-items: end;
  }

  #{{ section_id }} .nwy-about__materials-copy .nwy-about__body {
    margin-left: 0;
  }

  #{{ section_id }} .nwy-about__materials-list {
    border-top: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__material {
    display: grid;
    grid-template-columns: 45px 1fr;
    gap: 20px;
    align-items: center;
    padding-block: 26px;
    border-bottom: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__material-number {
    color: var(--nwy-about-muted);
    font-size: 11px;
    letter-spacing: 0.1em;
  }

  #{{ section_id }} .nwy-about__material p {
    margin-bottom: 0;
    font-size: clamp(19px, 1.6vw, 27px);
    font-weight: 600;
    letter-spacing: -0.035em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__after {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: clamp(65px, 10vw, 170px);
    align-items: end;
  }

  #{{ section_id }} .nwy-about__after .nwy-about__display-heading {
    margin-bottom: 0;
  }

  #{{ section_id }} .nwy-about__after-copy .nwy-about__body {
    margin-left: 0;
  }

  #{{ section_id }} .nwy-about__gallery {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(320px, 0.75fr);
    gap: 12px;
    padding-bottom: clamp(100px, 13vw, 220px);
  }

  #{{ section_id }} .nwy-about__gallery-main {
    min-height: 740px;
    overflow: hidden;
  }

  #{{ section_id }} .nwy-about__gallery-side {
    display: grid;
    gap: 12px;
  }

  #{{ section_id }} .nwy-about__gallery-small {
    min-height: 360px;
    overflow: hidden;
  }

  #{{ section_id }} .nwy-about__studio {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(60px, 10vw, 170px);
    align-items: center;
    border-top: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__studio-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  #{{ section_id }} .nwy-about__studio-copy .nwy-about__body {
    margin-left: 0;
  }

  #{{ section_id }} .nwy-about__final {
    padding-block: clamp(120px, 16vw, 260px) clamp(85px, 10vw, 150px);
    border-top: 1px solid var(--nwy-about-border);
  }

  #{{ section_id }} .nwy-about__final-heading {
    max-width: 1600px;
    margin-bottom: clamp(70px, 10vw, 150px);
    font-size: clamp(70px, 11vw, 190px);
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.075em;
    text-transform: uppercase;
  }

  #{{ section_id }} .nwy-about__final-bottom {
    display: flex;
    justify-content: space-between;
    gap: 40px;
    align-items: flex-end;
  }

  #{{ section_id }} .nwy-about__final-text {
    max-width: 600px;
    margin-bottom: 0;
    font-size: clamp(18px, 1.7vw, 27px);
    line-height: 1.4;
  }

  #{{ section_id }} .nwy-about__button {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: space-between;
    gap: 50px;
    border: 1px solid currentColor;
    padding: 0 20px;
    color: inherit;
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background 300ms ease,
      color 300ms ease;
  }

  #{{ section_id }} .nwy-about__button svg {
    width: 18px;
    height: 18px;
    transition: transform 300ms cubic-bezier(0.22, 1, 0.36, 1);

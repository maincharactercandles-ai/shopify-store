
<div class="section-background" style="background: {{ section.settings.background_color }};"></div>

<div
  class="section section--page-width nwye-newsletter"
  style="
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="nwye-newsletter__wrap">

    {%- if section.settings.label != blank -%}
      <p class="nwye-newsletter__label">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h2 class="nwye-newsletter__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="nwye-newsletter__sub">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'nwye-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="nwye-newsletter__form">
        <input
          class="nwye-newsletter__input"
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
          required
          autocomplete="email"
        >
        <button class="nwye-newsletter__btn" type="submit">
          {{ section.settings.button_label | default: 'Subscribe' }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="nwye-newsletter__success">
          {{ section.settings.success_message | default: "You're in. Welcome to the inside." }}
        </p>
      {%- endif -%}
    {%- endform -%}

  </div>
</div>

{% stylesheet %}
.nwye-newsletter {
  text-align: center;
}
.nwye-newsletter__wrap {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-width-padding, 24px);
}
.nwye-newsletter__label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.6;
  margin-bottom: 20px;
}
.nwye-newsletter__title {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.01em;
  margin-bottom: 12px;
}
.nwye-newsletter__sub {
  font-size: 0.875rem;
  opacity: 0.7;
  margin-bottom: 32px;
}
.nwye-newsletter__form {
  display: flex;
  gap: 8px;
  justify-content: center;
  max-width: 480px;
  margin: 0 auto;
}
.nwye-newsletter__input {
  flex: 1;
  padding: 14px 20px;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.3);
  color: inherit;
  font-size: 0.875rem;
  border-radius: 14px;
  outline: none;
  font-family: inherit;
}
.nwye-newsletter__input::placeholder {
  color: rgba(255,255,255,0.5);
}
.nwye-newsletter__btn {
  padding: 14px 28px;
  background: #ffffff;
  color: #1800ad;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  border-radius: 14px;
  cursor: pointer;
  white-space: nowrap;
  font-family: inherit;
  transition: opacity 0.2s;
}
.nwye-newsletter__btn:hover {
  opacity: 0.85;
}
.nwye-newsletter__success {
  margin-top: 16px;
  font-size: 0.85rem;
  opacity: 0.85;
  font-weight: 500;
}
@media screen and (max-width: 600px) {
  .nwye-newsletter__form {
    flex-direction: column;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter Band",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1800ad"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (small caps)",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "First to know."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "New collections, exclusive drops and subscriber-only offers."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in. Welcome to the inside."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter Band"
    }
  ]
}
{% endschema %}

{% liquid
  assign selected_collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
  assign heading_tag = section.settings.heading_tag
%}

<section
  id="NWY-Coming-{{ section.id }}"
  class="nwy-coming"
  style="
    --nwy-coming-bg: {{ section.settings.background_color }};
    --nwy-coming-text: {{ section.settings.text_color }};
    --nwy-coming-muted: {{ section.settings.muted_text_color }};
    --nwy-coming-card-bg: {{ section.settings.card_background }};
    --nwy-coming-overlay: {{ section.settings.overlay_color }};
    --nwy-coming-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --nwy-coming-gutter: {{ section.settings.side_gutter }}px;
    --nwy-coming-max-width: {{ section.settings.max_width }}px;
    --nwy-coming-pt: {{ section.settings.padding_top }}px;
    --nwy-coming-pb: {{ section.settings.padding_bottom }}px;
    --nwy-coming-ratio: {{ section.settings.image_ratio }};
  "
>
  <div class="nwy-coming__inner">
    <div class="nwy-coming__layout">
      <div class="nwy-coming__intro">
        {% if section.settings.eyebrow != blank %}
          <p class="nwy-coming__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.title != blank %}
          <{{ heading_tag }} class="nwy-coming__title">
            {{ section.settings.title | escape }}
          </{{ heading_tag }}>
        {% endif %}

        {% if section.settings.tagline != blank %}
          <p class="nwy-coming__tagline">
            {{ section.settings.tagline | escape | newline_to_br }}
          </p>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="nwy-coming__description rte">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.form_heading != blank %}
          <p class="nwy-coming__form-heading">
            {{ section.settings.form_heading | escape }}
          </p>
        {% endif %}

        {% form 'customer', class: 'nwy-coming__form' %}
          <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tag | escape }}">

          {% if form.posted_successfully? %}
            <p class="nwy-coming__success" role="status">
              {{ section.settings.success_message | escape }}
            </p>
          {% else %}
            <div class="nwy-coming__form-row">
              <label class="visually-hidden" for="NWY-Email-{{ section.id }}">
                {{ section.settings.email_label | escape }}
              </label>

              <input
                id="NWY-Email-{{ section.id }}"
                class="nwy-coming__input"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
              >

              <button class="nwy-coming__submit" type="submit">
                <span>{{ section.settings.button_label | escape }}</span>
                <span aria-hidden="true">↗</span>
              </button>
            </div>

            {% if form.errors %}
              <div class="nwy-coming__errors" role="alert">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
          {% endif %}
        {% endform %}
      </div>

      <div class="nwy-coming__products">
        {% if selected_collection != blank and selected_collection.products_count > 0 %}
          <div
            class="nwy-coming__grid"
            role="list"
            style="--nwy-coming-columns: {{ section.settings.columns_desktop }};"
          >
            {% for product in selected_collection.products limit: products_limit %}
              {% liquid
                assign product_number = section.settings.object_start_number | plus: forloop.index0
                assign product_image = product.featured_media
              %}

              <article class="nwy-coming-card" role="listitem">
                <a class="nwy-coming-card__link" href="{{ product.url }}">
                  <div class="nwy-coming-card__media">
                    {% if product_image != blank %}
                      {{
                        product_image
                        | image_url: width: 1400
                        | image_tag:
                          class: 'nwy-coming-card__image',
                          widths: '320, 480, 640, 800, 1000, 1200, 1400',
                          sizes: '(min-width: 1200px) 24vw, (min-width: 750px) 31vw, 86vw',
                          loading: 'lazy',
                          alt: product_image.alt | default: product.title
                      }}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'nwy-coming-card__placeholder' }}
                    {% endif %}

                    {% if section.settings.show_overlay %}
                      <span class="nwy-coming-card__veil" aria-hidden="true"></span>
                    {% endif %}

                    {% if section.settings.badge_text != blank %}
                      <span class="nwy-coming-card__badge">
                        {{ section.settings.badge_text | escape }}
                      </span>
                    {% endif %}
                  </div>

                  <div class="nwy-coming-card__content">
                    {% if section.settings.show_object_number %}
                      <p class="nwy-coming-card__object">
                        OBJECT {{ product_number | prepend: '0' | slice: -2, 2 }}
                      </p>
                    {% endif %}

                    <h3 class="nwy-coming-card__title">{{ product.title | escape }}</h3>

                    {% if section.settings.show_description %}
                      {% assign short_description = product.metafields.custom.short_description.value | default: product.description %}
                      {% if short_description != blank %}
                        <div class="nwy-coming-card__description">
                          {{ short_description | strip_html | truncatewords: section.settings.description_words }}
                        </div>
                      {% endif %}
                    {% endif %}

                    <span class="nwy-coming-card__notify">
                      {{ section.settings.card_link_label | escape }}
                      <span aria-hidden="true">→</span>
                    </span>
                  </div>
                </a>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="nwy-coming__empty">
            <p>Sélectionne la collection Drop 02 dans les réglages.</p>

            <div
              class="nwy-coming__grid"
              role="list"
              style="--nwy-coming-columns: {{ section.settings.columns_desktop }};"
            >
              {% for i in (1..3) %}
                <article class="nwy-coming-card" role="listitem">
                  <div class="nwy-coming-card__media">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'nwy-coming-card__placeholder' }}
                    <span class="nwy-coming-card__veil" aria-hidden="true"></span>
                    <span class="nwy-coming-card__badge">{{ section.settings.badge_text | escape }}</span>
                  </div>
                  <div class="nwy-coming-card__content">
                    <p class="nwy-coming-card__object">
                      OBJECT {{ section.settings.object_start_number | plus: forloop.index0 | prepend: '0' | slice: -2, 2 }}
                    </p>
                    <h3 class="nwy-coming-card__title">Product title</h3>
                    <span class="nwy-coming-card__notify">
                      {{ section.settings.card_link_label | escape }} →
                    </span>
                  </div>
                </article>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% style %}
  #NWY-Coming-{{ section.id }} {
    background: var(--nwy-coming-bg);
    color: var(--nwy-coming-text);
    padding-block: var(--nwy-coming-pt) var(--nwy-coming-pb);
  }

  #NWY-Coming-{{ section.id }} * {
    box-sizing: border-box;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__inner {
    width: min(
      calc(100% - (var(--nwy-coming-gutter) * 2)),
      var(--nwy-coming-max-width)
    );
    margin-inline: auto;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__layout {
    display: grid;
    grid-template-columns: minmax(240px, 0.78fr) minmax(0, 2.22fr);
    gap: clamp(44px, 5.5vw, 100px);
    align-items: start;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__intro {
    position: sticky;
    top: 100px;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__eyebrow {
    margin: 0 0 18px;
    color: var(--nwy-coming-muted);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__title {
    max-width: 8.5ch;
    margin: 0;
    color: var(--nwy-coming-text);
    font-size: clamp(36px, 4vw, 70px);
    font-weight: 700;
    line-height: 0.91;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    text-wrap: balance;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__tagline {
    max-width: 17ch;
    margin: 30px 0 0;
    font-size: clamp(19px, 1.8vw, 28px);
    font-weight: 500;
    line-height: 1.09;
    letter-spacing: -0.035em;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__description {
    max-width: 38ch;
    margin-top: 26px;
    color: var(--nwy-coming-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__description > *:first-child {
    margin-top: 0;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__description > *:last-child {
    margin-bottom: 0;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__form-heading {
    margin: 34px 0 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__form-row {
    display: flex;
    max-width: 420px;
    border-bottom: 1px solid var(--nwy-coming-text);
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__input {
    min-width: 0;
    flex: 1 1 auto;
    padding: 14px 2px;
    border: 0;
    border-radius: 0;
    outline: none;
    background: transparent;
    color: var(--nwy-coming-text);
    font: inherit;
    font-size: 13px;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__input::placeholder {
    color: var(--nwy-coming-muted);
    opacity: 1;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__submit {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 13px;
    padding: 0 2px 0 18px;
    border: 0;
    background: transparent;
    color: var(--nwy-coming-text);
    cursor: pointer;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__success,
  #NWY-Coming-{{ section.id }} .nwy-coming__errors {
    margin-top: 14px;
    font-size: 12px;
    line-height: 1.4;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__grid {
    display: grid;
    grid-template-columns: repeat(var(--nwy-coming-columns), minmax(0, 1fr));
    gap: clamp(18px, 2vw, 34px);
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card {
    min-width: 0;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: var(--nwy-coming-ratio);
    background: var(--nwy-coming-card-bg);
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__image,
  #NWY-Coming-{{ section.id }} .nwy-coming-card__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__image {
    object-fit: cover;
    transform: scale(1.002);
    transition:
      transform 800ms cubic-bezier(0.2, 0.75, 0.25, 1),
      filter 350ms ease;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--nwy-coming-overlay);
    opacity: var(--nwy-coming-overlay-opacity);
    transition: opacity 350ms ease;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__badge {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2;
    width: max-content;
    max-width: calc(100% - 30px);
    transform: translate(-50%, -50%);
    color: #ffffff;
    font-size: clamp(11px, 1vw, 15px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__content {
    padding-top: 15px;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__object {
    margin: 0 0 7px;
    color: var(--nwy-coming-muted);
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__title {
    margin: 0;
    color: var(--nwy-coming-text);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__description {
    max-width: 30ch;
    margin-top: 8px;
    color: var(--nwy-coming-muted);
    font-size: 12px;
    line-height: 1.42;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__notify {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 18px;
    padding-bottom: 3px;
    border-bottom: 1px solid currentColor;
    color: var(--nwy-coming-text);
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__link:hover .nwy-coming-card__image {
    transform: scale(1.04);
  }

  #NWY-Coming-{{ section.id }} .nwy-coming-card__link:hover .nwy-coming-card__veil {
    opacity: calc(var(--nwy-coming-overlay-opacity) - 0.08);
  }

  #NWY-Coming-{{ section.id }} .nwy-coming__empty > p {
    margin: 0 0 24px;
    color: var(--nwy-coming-muted);
    font-size: 13px;
  }

  @media screen and (max-width: 1199px) {
    #NWY-Coming-{{ section.id }} .nwy-coming__layout {
      grid-template-columns: minmax(220px, 0.7fr) minmax(0, 1.55fr);
      gap: 44px;
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    #NWY-Coming-{{ section.id }} {
      padding-block:
        calc(var(--nwy-coming-pt) * 0.72)
        calc(var(--nwy-coming-pb) * 0.72);
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__inner {
      width: calc(100% - 32px);
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__layout {
      display: block;
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__intro {
      position: static;
      margin-bottom: 48px;
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__title {
      font-size: clamp(43px, 13vw, 66px);
    }

    #NWY-Coming-{{ section.id }} .nwy-coming__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    #NWY-Coming-{{ section.id }} .nwy-coming-card__media {
      aspect-ratio: 4 / 5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #NWY-Coming-{{ section.id }} *,
    #NWY-Coming-{{ section.id }} *::before,
    #NWY-Coming-{{ section.id }} *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "NWY — Drop à venir",
  "tag": "section",
  "class": "section-nwy-coming",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Numéro du drop",
      "default": "DROP 02"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "GLASS OBJECTS"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Balise du titre",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ]
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Phrase signature",
      "default": "New chapter.\nSame philosophy."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Glass, colour and transparency. A new collection of objects designed to diffuse light, elevate spaces and remain long after the candle is gone.</p><p><strong>Coming soon.</strong></p>"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection Drop 02"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Produits à afficher",
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Colonnes sur ordinateur",
      "default": 3
    },
    {
      "type": "header",
      "content": "Liste d’attente"
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Titre du formulaire",
      "default": "BE THE FIRST TO KNOW."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Libellé e-mail",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Texte dans le champ",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "NOTIFY ME"
    },
    {
      "type": "text",
      "id": "customer_tag",
      "label": "Tag client Shopify",
      "default": "drop-02-waitlist"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Message de confirmation",
      "default": "YOU’RE ON THE LIST."
    },
    {
      "type": "header",
      "content": "Cartes produits"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format des images",
      "default": "4 / 5",
      "options": [
        { "value": "1 / 1", "label": "Carré" },
        { "value": "4 / 5", "label": "Portrait" },
        { "value": "3 / 4", "label": "Portrait long" },
        { "value": "4 / 3", "label": "Paysage" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_object_number",
      "label": "Afficher OBJECT 04, OBJECT 05…",
      "default": true
    },
    {
      "type": "range",
      "id": "object_start_number",
      "min": 1,
      "max": 99,
      "step": 1,
      "label": "Premier numéro d’objet",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Afficher une courte description",
      "default": true
    },
    {
      "type": "range",
      "id": "description_words",
      "min": 3,
      "max": 25,
      "step": 1,
      "label": "Nombre de mots",
      "default": 8
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge sur l’image",
      "default": "COMING SOON"
    },
    {
      "type": "text",
      "id": "card_link_label",
      "label": "Lien sous chaque produit",
      "default": "DISCOVER"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Assombrir légèrement les images",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Opacité de l’assombrissement",
      "default": 20
    },
    {
      "type": "header",
      "content": "Largeur et marges"
    },
    {
      "type": "range",
      "id": "side_gutter",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marges latérales",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1200,
      "max": 2400,
      "step": 100,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 2000
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Fond de la section",
      "default": "#F1F0EB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texte principal",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Texte secondaire",
      "default": "#6E6E68"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Fond des images",
      "default": "#E3E1DA"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Couleur de l’assombrissement",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Marge haute",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Marge basse",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "NWY — Drop à venir"
    }
  ]
}
{% endschema %}

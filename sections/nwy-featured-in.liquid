{% liquid
assign s = section.settings
%}

<section class="nwy-proof">
  <div class="page-width">

    <div class="nwy-proof__grid">

      <!-- LEFT -->
      <div class="nwy-proof__col">
        <span class="eyebrow">{{ s.left_label }}</span>

        <div class="logos">
          {% if s.logo_1 != blank %}
            <img src="{{ s.logo_1 | image_url: width: 300 }}" alt="">
          {% endif %}

          {% if s.logo_2 != blank %}
            <img src="{{ s.logo_2 | image_url: width: 300 }}" alt="">
          {% endif %}
        </div>
      </div>

      <!-- CENTER -->
      <div class="nwy-proof__col center">

        <span class="eyebrow">{{ s.review_label }}</span>

        <div class="stars">★★★★★</div>

        <blockquote>
          "{{ s.quote }}"
        </blockquote>

        <p class="author">— {{ s.author }}</p>

      </div>

      <!-- RIGHT -->
      <div class="nwy-proof__col">

        <div class="gallery">

          {% for block in section.blocks %}

            {% if block.settings.image != blank %}
              <div class="gallery-item">
                <img
                  src="{{ block.settings.image | image_url: width: 500 }}"
                  alt=""
                  loading="lazy">
              </div>
            {% endif %}

          {% endfor %}

        </div>

      </div>

    </div>

  </div>
</section>

<style>

.nwy-proof{
padding:90px 0;
background:#fff;
}

.nwy-proof__grid{
display:grid;
grid-template-columns:1fr 1fr 1.2fr;
gap:60px;
align-items:center;
}

.eyebrow{
display:block;
font-size:11px;
letter-spacing:.18em;
text-transform:uppercase;
color:#999;
margin-bottom:26px;
}

.logos{
display:flex;
align-items:center;
gap:55px;
}

.logos img{
max-height:42px;
width:auto;
opacity:.95;
}

.center{
border-left:1px solid #eee;
border-right:1px solid #eee;
padding:0 45px;
}

.stars{
font-size:18px;
letter-spacing:4px;
margin-bottom:18px;
}

blockquote{
font-size:22px;
line-height:1.5;
margin:0 0 18px;
font-weight:500;
}

.author{
font-size:15px;
color:#666;
margin:0;
}

.gallery{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:12px;
}

.gallery-item{
overflow:hidden;
aspect-ratio:1;
}

.gallery-item img{
width:100%;
height:100%;
object-fit:cover;
transition:.45s;
}

.gallery-item:hover img{
transform:scale(1.05);
}

@media(max-width:990px){

.nwy-proof__grid{
grid-template-columns:1fr;
gap:50px;
}

.center{
border:0;
padding:0;
}

.gallery{
grid-template-columns:repeat(3,1fr);
}

.logos{
justify-content:center;
}

}

</style>

{% schema %}
{
  "name":"NWY - Proof",
  "settings":[
    {
      "type":"text",
      "id":"left_label",
      "label":"Left label",
      "default":"Selected by"
    },
    {
      "type":"image_picker",
      "id":"logo_1",
      "label":"Logo 1"
    },
    {
      "type":"image_picker",
      "id":"logo_2",
      "label":"Logo 2"
    },
    {
      "type":"text",
      "id":"review_label",
      "label":"Review label",
      "default":"What they say"
    },
    {
      "type":"textarea",
      "id":"quote",
      "label":"Quote",
      "default":"Probably the most beautiful candles I've ever bought. The design is insane and the scents are incredible."
    },
    {
      "type":"text",
      "id":"author",
      "label":"Author",
      "default":"Camille, Paris"
    }
  ],
  "blocks":[
    {
      "type":"image",
      "name":"Image",
      "settings":[
        {
          "type":"image_picker",
          "id":"image",
          "label":"Image"
        }
      ]
    }
  ],
  "presets":[
    {
      "name":"NWY - Proof",
      "blocks":[
        {"type":"image"},
        {"type":"image"},
        {"type":"image"}
      ]
    }
  ]
}
{% endschema %}
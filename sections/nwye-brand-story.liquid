
<div class="section-background" style="background: {{ section.settings.background_color }};"></div>

<div
  class="section section--page-width nwye-brand-story"
  style="
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="nwye-brand-story__inner">

    <div class="nwye-brand-story__content">
      {%- if section.settings.label != blank -%}
        <p class="nwye-brand-story__label">{{ section.settings.label }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="nwye-brand-story__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="nwye-brand-story__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="nwye-brand-story__btn"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="nwye-brand-story__visual">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 900
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 900',
            class: 'nwye-brand-story__img'
        }}
      {%- else -%}
        <div class="nwye-brand-story__img-placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% stylesheet %}
.nwye-brand-story {
  overflow: hidden;
}
.nwye-brand-story__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-width-padding, 24px);
}
.nwye-brand-story__label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.45;
  margin-bottom: 20px;
}
.nwye-brand-story__title {
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}
.nwye-brand-story__text {
  font-size: 0.95rem;
  line-height: 1.75;
  opacity: 0.7;
  margin-bottom: 36px;
}
.nwye-brand-story__btn {
  display: inline-block;
  padding: 14px 32px;
  background: #ffffff;
  color: #000000;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 14px;
  transition: background 0.2s, color 0.2s;
}
.nwye-brand-story__btn:hover {
  background: #097e14;
  color: #ffffff;
}
.nwye-brand-story__visual {
  aspect-ratio: 4 / 5;
  border-radius: 4px;
  overflow: hidden;
  background: #1a1a1a;
}
.nwye-brand-story__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.nwye-brand-story__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.15;
}
.nwye-brand-story__img-placeholder svg {
  width: 64px;
  height: 64px;
}
@media screen and (max-width: 900px) {
  .nwye-brand-story__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .nwye-brand-story__visual {
    order: -1;
    aspect-ratio: 3 / 2;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (small caps)",
      "default": "Our story"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Candles unlike\nanything else."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Not What You Expect was born from an obsession: to create candles that surprise, provoke, and stay with you. Hand-poured in Paris, each piece is designed to challenge the codes of décor and leave a mark — olfactory, visual, emotional.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Discover our world"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image (lifestyle / studio)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}

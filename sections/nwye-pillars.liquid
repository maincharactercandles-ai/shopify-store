
<div class="section-background" style="background: {{ section.settings.background_color }};"></div>

<div
  class="section section--page-width nwye-pillars"
  style="
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="nwye-pillars__wrap">

    {%- if section.settings.label != blank or section.settings.title != blank -%}
      <div class="nwye-pillars__header">
        {%- if section.settings.label != blank -%}
          <p class="nwye-pillars__label">{{ section.settings.label }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="nwye-pillars__title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="nwye-pillars__grid">
      {%- for block in section.blocks -%}
        <div
          class="nwye-pillar"
          style="border-top: 3px solid {{ block.settings.accent_color }};"
          {{ block.shopify_attributes }}
        >
          <div class="nwye-pillar__num" style="color: {{ block.settings.accent_color }};">
            {{ forloop.index | prepend: '0' | slice: -2, 2 }}
          </div>
          {%- if block.settings.name != blank -%}
            <div class="nwye-pillar__name">{{ block.settings.name }}</div>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="nwye-pillar__desc">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
.nwye-pillars__wrap {
  max-width: var(--page-width, 1200px);
  margin: 0 auto;
  padding: 0 var(--page-width-padding, 24px);
}
.nwye-pillars__header {
  text-align: center;
  margin-bottom: 64px;
}
.nwye-pillars__label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  opacity: 0.4;
  margin-bottom: 16px;
}
.nwye-pillars__title {
  font-size: clamp(1.5rem, 3vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}
.nwye-pillars__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.nwye-pillar {
  background: #f5f5f5;
  padding: 48px 40px;
  border-radius: 4px;
}
.nwye-pillar__num {
  font-size: 3rem;
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 1;
  margin-bottom: 20px;
}
.nwye-pillar__name {
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 12px;
  color: #000000;
}
.nwye-pillar__desc {
  font-size: 0.875rem;
  line-height: 1.7;
  color: #000000;
  opacity: 0.65;
}
@media screen and (max-width: 900px) {
  .nwye-pillars__grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Pillars",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (small caps)",
      "default": "What sets us apart"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "Made differently.\nFelt differently."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Title",
          "default": "Hand-Poured in Paris"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every candle is poured by hand in our Parisian studio. No mass production. Each piece is one of a kind."
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent color",
          "default": "#1800ad"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "name": "Hand-Poured in Paris",
            "text": "Every candle is poured by hand in our Parisian studio. No mass production. Each piece is one of a kind.",
            "accent_color": "#1800ad"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "name": "Premium Vegan Wax",
            "text": "100% plant-based formula, high-concentration fragrances. A clean, long burn with a scent that truly lasts.",
            "accent_color": "#fbb91d"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "name": "Unexpected Design",
            "text": "Objects that stand as décor just as much as candles. The outside surprises. The inside captivates.",
            "accent_color": "#097e14"
          }
        }
      ]
    }
  ]
}
{% endschema %}

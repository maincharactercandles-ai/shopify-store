<div class="nwye-pillars" style="background:#ffffff; padding:80px 24px;">
  <div style="max-width:1200px; margin:0 auto;">

    <div style="text-align:center; margin-bottom:56px;">
      <p style="font-size:0.65rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; opacity:0.4; margin-bottom:14px;">
        {{ section.settings.label }}
      </p>
      <h2 style="font-size:clamp(1.5rem,3vw,2.5rem); font-weight:700; letter-spacing:-0.02em; line-height:1.15;">
        {{ section.settings.title }}
      </h2>
    </div>

    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:3px;">

      {%- for block in section.blocks -%}
        <div style="background:#f5f5f5; border-top:3px solid {{ block.settings.accent_color }}; padding:44px 36px; border-radius:4px;" {{ block.shopify_attributes }}>
          <div style="font-size:2.8rem; font-weight:700; letter-spacing:-0.04em; color:{{ block.settings.accent_color }}; line-height:1; margin-bottom:18px;">
            0{{ forloop.index }}
          </div>
          <div style="font-size:0.8rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; margin-bottom:10px; color:#000;">
            {{ block.settings.name }}
          </div>
          <p style="font-size:0.875rem; line-height:1.7; color:#000; opacity:0.6; margin:0;">
            {{ block.settings.text }}
          </p>
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

<style>
  @media (max-width:768px) {
    .nwye-pillars > div > div:last-child {
      grid-template-columns: 1fr !important;
    }
  }
</style>

{% schema %}
{
  "name": "What Sets Us Apart",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "What sets us apart"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Made differently. Felt differently."
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent color",
          "default": "#1800ad"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What Sets Us Apart",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "name": "Hand-Poured in Paris",
            "text": "Every candle is poured by hand in our Parisian studio. No mass production. Each piece is one of a kind.",
            "accent_color": "#1800ad"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "name": "Premium Vegan Wax",
            "text": "100% plant-based formula, high-concentration fragrances. A clean, long burn with a scent that truly lasts.",
            "accent_color": "#fbb91d"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "name": "Unexpected Design",
            "text": "Objects that stand as décor just as much as candles. The outside surprises. The inside captivates.",
            "accent_color": "#097e14"
          }
        }
      ]
    }
  ]
}
{% endschema %}
